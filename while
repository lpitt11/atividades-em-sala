media_turma = 0
soma_das_notas = 0
quantidade_alunos = 0
i = 1
while i > 0:
    nota = float(input(f"Digite a nota de aluno: {quantidade_alunos}, digite valor negativo para cancelar "))
    if nota == -1:
        break
    else:
        soma_das_notas += nota
        quantidade_alunos += 1
media_turma = soma_das_notas/quantidade_alunos
print(f"A média da turma é: {media_turma}")
    

